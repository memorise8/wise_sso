AUTH_DB_ADMIN_PASSWORD="replace-postgres-admin-password"
AUTH_DB_PASSWORD="replace-auth-db-password"
AUTH_DB_PORT=5432
AUTH_DB_NAME="auth_db"
AUTH_DB_USER="auth_user"

DATABASE_URL="postgresql://auth_user:replace-auth-db-password@localhost:5432/auth_db"

PORT=4000
JWT_ACCESS_SECRET="replace-access-secret"
JWT_REFRESH_SECRET="replace-refresh-secret"
JWT_ISSUER="https://auth.temis.co.kr"
JWT_AUDIENCE="temis"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
PASSWORD_MIN_LENGTH=12
COMPANY_ALLOWED_EMAIL_DOMAIN=""
CORS_ALLOWED_ORIGINS="http://localhost:3000"
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=20

FRONTEND_REDIRECT_URL="http://localhost:3000/auth/callback"

MAIL_PROVIDER="dev"
MAIL_FROM="Auth <no-reply@example.com>"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/auth/google/callback"

NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_REDIRECT_URI="http://localhost:4000/auth/naver/callback"

KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI="http://localhost:4000/auth/kakao/callback"
